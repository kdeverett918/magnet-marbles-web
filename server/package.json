{
  "name": "magnet-marbles-server",
  "private": true,
  "version": "1.0.0",
  "description": "Authoritative Colyseus server for Magnet Marbles online multiplayer.",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=cjs",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@colyseus/ws-transport": "^0.16.0",
    "colyseus": "^0.16.0",
    "cors": "^2.8.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2"
  }
}
