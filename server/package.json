{
  "name": "magnet-marbles-server",
  "private": true,
  "version": "1.0.0",
  "description": "Authoritative Colyseus server for Magnet Marbles live online multiplayer.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@colyseus/core": "0.16.24",
    "@colyseus/ws-transport": "0.16.5",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "nanoid": "file:vendor/nanoid-compat"
  },
  "overrides": {
    "nanoid": "$nanoid"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "esbuild": "0.28.1",
    "tsx": "^4.19.2"
  }
}
