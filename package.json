{
  "name": "magnet-marbles-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Magnet Marbles — a premium phone-first 3D magnetic marble arena game. Web build.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --host",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "vertical:slice": "vitest run src/game/data/verticalSlice.test.ts",
    "sim:soak": "vitest run src/game/sim/soak.test.ts",
    "validate:no-browser": "node scripts/no-browser-check.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "preview:smoke": "node scripts/preview-smoke.mjs",
    "modes:smoke": "node scripts/modes-smoke.mjs",
    "live:smoke": "node scripts/live-web-smoke.mjs",
    "metadata:smoke": "node scripts/metadata-smoke.mjs",
    "ip:safety": "node scripts/ip-safety-smoke.mjs",
    "build-info:smoke": "node scripts/build-info-smoke.mjs",
    "source:fingerprint": "node scripts/source-fingerprint-smoke.mjs",
    "aa:readiness": "node scripts/aa-readiness-smoke.mjs",
    "assets:smoke": "node scripts/assets-smoke.mjs",
    "dist:budget": "node scripts/dist-budget-smoke.mjs",
    "browser:guard": "node scripts/browser-guard-smoke.mjs",
    "clean-exit:smoke": "node scripts/clean-exit-smoke.mjs",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "perf:mobile:smoke": "node scripts/mobile-perf-smoke.mjs",
    "soak:smoke": "node scripts/browser-soak-smoke.mjs",
    "online:smoke": "node scripts/online-smoke.mjs",
    "online:modes:smoke": "node scripts/online-modes-smoke.mjs",
    "online:disconnect:smoke": "node scripts/online-disconnect-smoke.mjs",
    "live:version": "node scripts/live-version-smoke.mjs",
    "deploy:monitor": "node scripts/deploy-monitor.mjs",
    "live:online:modes": "node scripts/live-online-modes-smoke.mjs",
    "a11y:smoke": "node scripts/a11y-smoke.mjs",
    "launch:check": "node scripts/launch-check.mjs",
    "release:verify": "node scripts/release-readiness.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "colyseus.js": "^0.16.0",
    "postprocessing": "^6.36.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
